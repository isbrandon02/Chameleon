# Google Veo (Vertex AI) — object replacement via Veo API
# When set, product replacement uses Veo instead of local YOLO+SAM+inpainting.
USE_VEO=true

# Required for Veo:
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GCS_BUCKET=your-bucket-name
VERTEX_AI_LOCATION=us-central1

# Optional: path to service account JSON (default: gcloud auth)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Optional: max output duration (seconds) to limit cost; Veo supports 5–8 sec (default: 8)
# VEO_MAX_DURATION_SEC=8
